# ==========================================
# Semantic Firewall - Environment Variables
# ==========================================

# 1. Upstream LLM Configuration
# Choose: Groq, Mistral, OpenAI, or DeepSeek
OPENAI_API_KEY=your_api_key_here
UPSTREAM_BASE_URL=https://api.groq.com/openai/v1

# 2. Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=semantic_cache
SIMILARITY_THRESHOLD=0.88

# 3. Database
# Use sqlite+aiosqlite:///./semantic_firewall.db for local dev
DATABASE_URL=sqlite+aiosqlite:///./semantic_firewall.db

# 4. Security & Environment
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_string_here
ENVIRONMENT=development